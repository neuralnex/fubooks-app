{
  "expo": {
    "name": "FUBOOKS",
    "slug": "fubooks",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "fubooks",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ng.futo.fubooks",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "FUBOOKS needs photo library access so admins can attach book cover images.",
        "NSCameraUsageDescription": "FUBOOKS needs camera access so admins can take photos of book covers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C4CF1"
      },
      "package": "ng.futo.fubooks",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "FUBOOKS needs photo library access so admins can attach book cover images."
        }
      ]
    ],
    "extra": {
      "privyAppId": "",
      "privyClientId": "",
      "eas": {
        "projectId": "c5feac66-98da-47e2-b73d-45f4a72c7207"
      }
    },
    "owner": "zionzurri",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c5feac66-98da-47e2-b73d-45f4a72c7207"
    }
  }
}
